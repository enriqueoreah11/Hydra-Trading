# ====== cTrader Open API (crea tu app en https://openapi.ctrader.com/apps) ======
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
# Debe coincidir EXACTAMENTE con el Redirect URI registrado en tu app de cTrader
CTRADER_REDIRECT_URI=https://TU-DOMINIO/oauth/callback
# demo | live  (empieza SIEMPRE en demo)
CTRADER_ENV=demo
# Lo obtienes tras el OAuth en /oauth/callback (ctidTraderAccountId)
CTRADER_ACCOUNT_ID=0

# ====== Anthropic ======
ANTHROPIC_API_KEY=
MODEL=claude-opus-4-8

# ====== Universo y cadencia ======
SYMBOLS=EURUSD,XAUUSD
TIMEFRAME=M15
ANALYSIS_INTERVAL_MIN=15
OVERNIGHT_INTERVAL_MIN=30
REVIEW_HOUR_UTC=21

# ====== Limites duros de riesgo (el Arquitecto NO puede tocarlos) ======
# true = modo papel: registra las ordenes en el diario pero NO las envia
DRY_RUN=true
RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_OPEN_POSITIONS=3
MIN_CONFIDENCE=65
MIN_RISK_REWARD=1.5
EQUITY_FLOOR_PCT=80.0

# ====== Sentinel — bloqueo por noticias (calendario economico) ======
ENABLE_NEWS=true
NEWS_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
# High | Medium | Low  (impacto minimo que bloquea nuevas entradas)
NEWS_IMPACT_MIN=High
NEWS_BLACKOUT_BEFORE_MIN=30
NEWS_BLACKOUT_AFTER_MIN=15
NEWS_REFRESH_MIN=180

# ====== Watchdog + notificaciones por Telegram ======
# Crea un bot con @BotFather y pon aqui el token; deja vacio para desactivar avisos.
TELEGRAM_BOT_TOKEN=
# Tu chat id (habla con @userinfobot para obtenerlo)
TELEGRAM_CHAT_ID=
WATCHDOG_INTERVAL_MIN=5
DATA_STALE_ALERT_MIN=20
ERROR_BURST_THRESHOLD=5
HEARTBEAT_HOUR_UTC=8

# ====== Auditor / reconciliador ======
ENABLE_AUDITOR=true
AUDITOR_INTERVAL_MIN=20
AUTO_HALT_ON_DISCREPANCY=true

# ====== Validador de playbook (backtest ligero antes de activar cambios) ======
VALIDATE_PLAYBOOK=true
BACKTEST_BARS=400
# nº de puntos de decision muestreados por simbolo (mayor = mas coste de LLM)
BACKTEST_SAMPLES=12
BACKTEST_HORIZON_BARS=24

# ====== Riesgo de portafolio / correlacion ======
ENABLE_PORTFOLIO_CHECK=true
MAX_CURRENCY_EXPOSURE_PCT=2.0
MAX_CORRELATION=0.7

# ====== Web ======
WEB_HOST=0.0.0.0
WEB_PORT=8000
# si lo defines, /halt y /resume requieren ?token=...
DASHBOARD_TOKEN=

# ====== Almacenamiento (usa un volumen persistente en la nube) ======
DATA_DIR=./data
