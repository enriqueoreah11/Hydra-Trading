# ====== cTrader Open API (crea tu app en https://openapi.ctrader.com/apps) ======
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
# Debe coincidir EXACTAMENTE con el Redirect URI registrado en tu app de cTrader
CTRADER_REDIRECT_URI=https://TU-DOMINIO/oauth/callback
# demo | live  (empieza SIEMPRE en demo)
CTRADER_ENV=demo
# Lo obtienes tras el OAuth en /oauth/callback (ctidTraderAccountId)
CTRADER_ACCOUNT_ID=0

# ====== Anthropic ======
ANTHROPIC_API_KEY=
MODEL=claude-opus-4-8

# ====== Universo y cadencia ======
SYMBOLS=EURUSD,XAUUSD
TIMEFRAME=M15
ANALYSIS_INTERVAL_MIN=15
OVERNIGHT_INTERVAL_MIN=30
REVIEW_HOUR_UTC=21

# ====== Limites duros de riesgo (el Arquitecto NO puede tocarlos) ======
# true = modo papel: registra las ordenes en el diario pero NO las envia
DRY_RUN=true
RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_OPEN_POSITIONS=3
MIN_CONFIDENCE=65
MIN_RISK_REWARD=1.5
EQUITY_FLOOR_PCT=80.0

# ====== Web ======
WEB_HOST=0.0.0.0
WEB_PORT=8000
# si lo defines, /halt y /resume requieren ?token=...
DASHBOARD_TOKEN=

# ====== Almacenamiento (usa un volumen persistente en la nube) ======
DATA_DIR=./data
